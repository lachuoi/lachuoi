# --- La Chuoi Master Configuration ---

# Database (libSQL / Turso)
# For local development: "tasks.db"
# For production: "libsql://your-db.turso.io"
TURSO_DATABASE_URL="tasks.db"
# TURSO_AUTH_TOKEN="your-secret-token"

# GitHub OAuth (for Dashboard Login)
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URL="http://127.0.0.1:9130/auth/github/callback"

# Security
# Shared secret key for Worker nodes to connect
LACHUOI_API_KEY="a-very-strong-secret-key"

# Optional: Web server port (defaults to 9130)
# PORT=9130
