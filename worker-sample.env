# The WebSocket URL of the master node
# For local dev: ws://127.0.0.1:9130/ws/worker
# For production: wss://your-master-domain.com/ws/worker (port 443)
LACHUOI_MASTER_WS_URL="ws://127.0.0.1:9130/ws/worker"
# Security
# Environment (development or production)
ENVIRONMENT="production"

# Must match the Master node's NODE_KEY
NODE_KEY="a-very-strong-secret-key"
